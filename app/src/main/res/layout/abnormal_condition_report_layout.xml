<?xml version="1.0" encoding="utf-8"?>
<com.ramotion.foldingcell.FoldingCell xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:folding-cell="http://schemas.android.com/apk/res-auto"
    android:id="@+id/folding_cell"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="2dp"
    android:layout_marginTop="5dp"
    android:layout_marginRight="2dp"
    android:layout_marginBottom="5dp"
    folding-cell:additionalFlipsCount="3"
    folding-cell:animationDuration="1300"
    folding-cell:backSideColor="@color/blue"
    folding-cell:cameraHeight="20">

    <include
        android:id="@+id/abnormalContentLayout"
        layout="@layout/abnormal_content_layout" />

   <!-- <include
        android:id="@+id/abnormalTitleLayout"
        layout="@layout/abnormal_title_layout" />-->

</com.ramotion.foldingcell.FoldingCell>