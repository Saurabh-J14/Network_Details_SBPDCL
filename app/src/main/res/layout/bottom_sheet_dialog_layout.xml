<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:visibility="visible"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet_layout1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    app:behavior_hideable="true"
    android:background="@color/white"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

<!--    app:behavior_peekHeight="62dp"-->

    <LinearLayout
        android:weightSum="2.0"
        android:id="@+id/bottom_sheet_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        android:orientation="horizontal"
        android:paddingTop="8sp"
        android:paddingBottom="2sp">

        <TextView
            android:layout_weight="1.0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="@string/load_flow_analysis"
            android:textColor="@color/white"
            android:paddingLeft="8sp"/>

        <ImageView
            android:layout_weight="1.0"
            android:id="@+id/bottom_sheet_arrow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

<!--        app:srcCompat="@drawable/baseline_keyboard_double_arrow_down_24"-->

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="5sp" >

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/configuration"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:layout_marginLeft="5sp"/>

            <Spinner
                android:id="@+id/purpose_visit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:spinnerMode="dropdown"
                style="@style/tag_spinner_style"
                android:paddingTop="5sp"
                android:prompt="@string/defaults" />

<!--            android:layout_marginRight="10dp"-->
<!--            android:layout_marginLeft="10dp"-->

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    >
                    <!--                app:tabMode="fixed"-->
                </com.google.android.material.tabs.TabLayout>



            <androidx.viewpager.widget.ViewPager
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>



    </RelativeLayout>

</LinearLayout>