<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.fragment.loadFlowAnalysis.ControlsFragment">

   <LinearLayout
       android:id="@+id/args_layout"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:orientation="vertical"
       android:layout_marginLeft="8sp"
       android:layout_marginRight="8sp"
       android:layout_marginTop="5sp">

      <TextView
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:text="@string/transformertapmode"
          android:textSize="13sp"
          android:textColor="@color/red"
          android:layout_marginLeft="7sp"
          android:textStyle="bold" />

      <Spinner
          android:id="@+id/transformerTabOperation"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:gravity="center_vertical"
          android:spinnerMode="dropdown"
          style="@style/tag_spinner_style"
          android:paddingTop="5sp"
          android:prompt="@string/defaults" />

      <TextView
          android:visibility="visible"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:text="@string/regular_tab_operation"
          android:textColor="@color/red"
          android:textSize="13sp"
          android:textStyle="bold"
          android:layout_marginLeft="7sp"/>

      <Spinner
          android:visibility="visible"
          android:id="@+id/regularTabOperation"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_centerVertical="true"
          android:gravity="center_vertical"
          android:spinnerMode="dropdown"
          style="@style/tag_spinner_style"
          android:paddingTop="5sp"
          android:prompt="@string/defaults"
          android:layout_marginBottom="5sp" />

      <LinearLayout
          android:weightSum="3.0"
          android:layout_below="@+id/args_layout"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:layout_marginLeft="7sp"
          android:layout_marginRight="7sp"
          android:gravity="center"
          android:layout_marginTop="5sp">

         <TextView
             android:visibility="visible"
             android:id="@+id/saveBtn"
             android:layout_weight="1.0"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:textStyle="bold"
             android:textSize="15sp"
             android:textAllCaps="false"
             android:layout_marginLeft="5sp"
             android:textColor="@color/black"
             android:gravity="center"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"/>

         <TextView
             android:id="@+id/cancelBtn"
             android:layout_weight="1.0"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="@string/cancel"
             android:textStyle="normal"
             android:textSize="18sp"
             android:textAllCaps="false"
             android:textColor="@color/white"
             android:gravity="center"
             android:background="@drawable/custom_btn_blue"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"
             android:layout_marginLeft="7sp" />

         <TextView
             android:id="@+id/okBtn"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:layout_marginLeft="7sp"
             android:layout_marginRight="7sp"
             android:layout_weight="1.10"
             android:background="@drawable/custom_btn_blue"
             android:gravity="center"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"
             android:text="@string/run"
             android:textAllCaps="false"
             android:textColor="@color/white"
             android:textSize="18sp"
             android:textStyle="normal" />

         <TextView
             android:visibility="gone"
             android:layout_weight="1.1"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="@string/ok"
             android:textStyle="bold"
             android:textSize="15sp"
             android:textAllCaps="false"
             android:layout_marginLeft="5sp"
             android:textColor="@color/black"
             android:gravity="center"
             android:background="@drawable/load_flow_btn_background"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"/>

      </LinearLayout>

      <LinearLayout
          android:visibility="gone"
          android:weightSum="4.0"
          android:layout_below="@+id/args_layout"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center"
          android:layout_marginTop="12sp">

         <TextView
             android:layout_weight="1.0"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="Run"
             android:textSize="15sp"
             android:textStyle="bold"
             android:textColor="@color/black"
             android:gravity="center"
             android:textAllCaps="false"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"
             android:background="@drawable/load_flow_btn_background" />

         <TextView
             android:layout_weight="1.0"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="Save"
             android:textStyle="bold"
             android:textSize="15sp"
             android:textAllCaps="false"
             android:layout_marginLeft="5sp"
             android:textColor="@color/black"
             android:gravity="center"
             android:background="@drawable/load_flow_btn_background"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"/>

         <TextView
             android:layout_weight="1.1"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="Ok"
             android:textStyle="bold"
             android:textSize="15sp"
             android:textAllCaps="false"
             android:layout_marginLeft="5sp"
             android:textColor="@color/black"
             android:gravity="center"
             android:background="@drawable/load_flow_btn_background"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"/>

         <TextView
             android:layout_weight="1.0"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:text="Cancel"
             android:textStyle="bold"
             android:textSize="15sp"
             android:textAllCaps="false"
             android:layout_marginLeft="5sp"
             android:textColor="@color/black"
             android:gravity="center"
             android:background="@drawable/load_flow_btn_background"
             android:paddingTop="8sp"
             android:paddingBottom="8sp"/>

      </LinearLayout>

   </LinearLayout>

</FrameLayout>