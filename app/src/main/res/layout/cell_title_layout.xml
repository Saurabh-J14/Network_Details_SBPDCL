<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:id="@+id/cell_title_view"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <RelativeLayout
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_weight="2"
        android:background="@color/blue"
        android:orientation="vertical"
        android:paddingBottom="20dp"
        android:paddingTop="10dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <LinearLayout
            android:id="@+id/colorLayout"
            android:weightSum="3.0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/overloadColorTv"
                android:layout_weight="1.0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/red"
                android:layout_margin="2dp"/>

            <TextView
                android:id="@+id/overVoltageColorTv"
                android:layout_weight="1.0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/red"
                android:layout_margin="2dp"/>

            <TextView
                android:id="@+id/underVoltageColorTv"
                android:layout_weight="1.0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/red"
                android:layout_margin="2dp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/codeImg"
            android:layout_below="@+id/colorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/transformer"
            android:gravity=""/>

        <LinearLayout
            android:layout_below="@+id/codeImg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/equipmentNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:text="Equipment No."
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/equipmentNoTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:text="DT-182385_29999"
                android:textStyle="bold"/>

        </LinearLayout>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@color/bgTitleRight"
        android:paddingBottom="10dp"
        android:paddingTop="10dp">

        <LinearLayout
            android:id="@+id/equipment_layout"
            android:weightSum="2.0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="5dp"
            android:paddingBottom="5dp"
            android:paddingTop="5dp">

            <LinearLayout
                android:layout_weight="0.2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:weightSum="2.0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/equipmentId"
                        android:layout_weight="1.40"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="EquipmentId :"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/equipmentIdTv"
                        android:layout_weight="0.62"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="400_11/0.433KV_DYN11_OIL"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <ImageView
                    android:id="@+id/title_from_to_dots_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="5dp"
                    android:src="@color/contentDividerLine" />

                <LinearLayout
                    android:weightSum="2.0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/code"
                        android:layout_weight="1.40"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Code : "
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/codeTv"
                        android:layout_weight="0.62"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Two-Winding Transformer"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_below="@+id/equipment_layout"
            android:id="@+id/node_layout"
            android:weightSum="2.0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:paddingLeft="2dp"
            android:paddingBottom="5dp"
            android:paddingTop="5dp">

            <ImageView
                android:id="@+id/nodeImg"
                android:layout_weight="1.9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"
                android:layout_marginRight="4dp"
                android:layout_marginLeft="4dp"
                android:src="@drawable/from_to_purple"
                android:layout_gravity="center"/>

            <LinearLayout
                android:layout_weight="0.2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:weightSum="2.0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/fromNode"
                        android:layout_weight="1.40"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="From Node : "
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/fromNodeTv"
                        android:layout_weight="0.62"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-999693.14_2167316.46"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="5dp"
                    android:layout_toEndOf="@+id/title_from_to_dots"
                    android:layout_toRightOf="@+id/title_from_to_dots"
                    android:src="@color/contentDividerLine" />

                <LinearLayout
                    android:weightSum="2.0"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/toNode"
                        android:layout_weight="1.40"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TO Node : "
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/toNodeTv"
                        android:layout_weight="0.62"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-999693.14_2167316.46"
                        android:textSize="10sp"
                        android:textStyle="bold"/>


                </LinearLayout>



            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</LinearLayout>