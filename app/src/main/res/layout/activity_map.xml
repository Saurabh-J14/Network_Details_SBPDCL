<?xml version="1.0" encoding="utf-8"?>
<com.techLabs.nbpdcl.Utils.WhalesDrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:openDrawer="start">

    <RelativeLayout
        android:id="@+id/r_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <org.osmdroid.views.MapView
            android:id="@+id/map"
            tilesource="Mapnik"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:clickable="true"
            android:drawingCacheQuality="high"
            android:nestedScrollingEnabled="true" />

        <LinearLayout
            android:id="@+id/menu_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:weightSum="3.0">

            <ImageButton
                android:id="@+id/drawer_btn"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:layout_weight=".20"
                android:background="@null"
                android:paddingStart="8sp"
                android:paddingTop="5sp"
                android:paddingEnd="5sp"
                android:paddingBottom="5sp"
                android:src="@drawable/menu_icons"
                app:tint="@color/blue" />

            <LinearLayout
                android:id="@+id/searchContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="2.9"
                android:elevation="8dp"
                android:gravity="center_vertical|end"
                android:orientation="horizontal"
                android:paddingEnd="10dp">

                <AutoCompleteTextView
                    android:id="@+id/searchView"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="-25dp"
                    android:layout_weight="0"
                    android:background="@drawable/search_bg"
                    android:hint="Search"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:textAlignment="viewStart"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:textSize="14sp"
                    android:visibility="invisible" />

                <ImageView
                    android:id="@+id/searchIcon"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/search_icon"
                    app:tint="@color/blue" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/survey_menu_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible"
            android:weightSum="3.0">

            <ImageButton
                android:id="@+id/survey_drawer_btn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1.350"
                android:background="@null"
                android:paddingStart="8sp"
                android:paddingTop="5sp"
                android:paddingEnd="5sp"
                android:paddingBottom="5sp"
                android:src="@drawable/menu_icons"
                app:tint="@color/blue" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="8sp"
                android:layout_weight="0.350"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="invisible">

                <AutoCompleteTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/search_box_background"
                    android:gravity="center"
                    android:hint="@string/search_here"
                    android:padding="5sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:visibility="gone" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/draw_option"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_weight="1.350"
                android:background="@drawable/add_section_background"
                android:padding="5dp"
                android:src="@drawable/line" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/side_l_Layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="100dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="95dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/tools_toggle_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/round_fab_bg"
                android:clipToOutline="true"
                android:contentDescription="Tools"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/features"
                app:tint="@color/white" />

            <LinearLayout
                android:id="@+id/tools_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/zoom_out"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/minimum"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/zoom_in"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="16dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/maximum"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/upTracing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/up_tracing"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/downTracing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/down_tracing"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/location_marker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/location_markers"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/analysis_img_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/renewable"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/new_connection_loadFlow_status_imgBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/new_connection_loadflow"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/reportBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/report"
                    android:visibility="visible"
                    app:tint="@color/blue" />

                <ImageButton
                    android:id="@+id/deleteBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@null"
                    android:paddingLeft="2sp"
                    android:paddingRight="2sp"
                    android:src="@drawable/delete"
                    android:visibility="visible"
                    app:tint="@color/blue" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/survey_l_Layout"
            android:layout_width="wrap_content"
            android:layout_height="350dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="100dp"
            android:layout_marginEnd="4dp"
            android:layout_marginBottom="95dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible">

            <ImageButton
                android:id="@+id/delete_section_survey_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@null"
                android:paddingLeft="2sp"
                android:paddingRight="2sp"
                android:src="@drawable/delete"
                android:visibility="visible"
                app:tint="@color/blue" />

            <ImageButton
                android:id="@+id/draw_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/add_section_background"
                android:padding="5dp"
                android:src="@drawable/new_line" />

            <ImageButton
                android:id="@+id/addNewNode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/add_section_background"
                android:padding="5dp"
                android:src="@drawable/ic_add_noode"
                app:tint="@color/blue" />

            <ImageButton
                android:id="@+id/add_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@null"
                android:paddingLeft="2sp"
                android:paddingRight="2sp"
                android:src="@drawable/location_markers"
                app:tint="@color/blue" />

            <ImageButton
                android:id="@+id/survey_zoom_out"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@null"
                android:paddingLeft="2sp"
                android:paddingRight="2sp"
                android:src="@drawable/minimum"
                app:tint="@color/blue" />

            <ImageButton
                android:id="@+id/survey_zoom_in"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:background="@null"
                android:paddingLeft="2sp"
                android:paddingRight="2sp"
                android:src="@drawable/maximum"
                app:tint="@color/blue" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/spinkitLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:orientation="vertical">

            <com.techLabs.nbpdcl.Utils.ProgressBarLayout
                android:id="@+id/progress_bar_layout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="visible" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/mapLayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/spinkitLayout"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/add_section_background"
            android:padding="8dp"
            android:src="@drawable/layer"
            android:visibility="visible"
            app:tint="@color/blue" />

        <ImageButton
            android:id="@+id/colorCodeView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/mapLayer"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/add_section_background"
            android:padding="8dp"
            android:src="@drawable/ic_legend"
            android:visibility="visible"
            app:tint="@color/blue" />

        <FrameLayout
            android:id="@+id/bottomContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:gravity="bottom" />

        <ImageButton
            android:id="@+id/locate_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@+id/mapLayer"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/add_section_background"
            android:padding="8dp"
            android:src="@drawable/locate_location"
            android:visibility="visible"
            app:tint="@color/blue" />

    </RelativeLayout>

    <FrameLayout
        android:id="@+id/sidebar_layout"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#fff"
        android:fitsSystemWindows="true"
        android:isScrollContainer="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="vertical"
            android:paddingStart="4sp"
            android:paddingEnd="10sp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="25dp"
                android:background="#cdcdcd"
                android:visibility="gone" />

            <SearchView
                android:id="@+id/search"
                style="@style/AppSearchView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5sp"
                android:background="@drawable/search_box_background"
                android:closeIcon="@drawable/ic_clear"
                android:iconifiedByDefault="false"
                android:queryHint="@string/hint_search_mess"
                android:searchHintIcon="@color/blue"
                android:searchIcon="@drawable/ic_search"
                android:textColor="@color/black"
                android:visibility="visible" />

            <ExpandableListView
                android:id="@+id/navigationmenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:groupIndicator="@drawable/expand_indicater"
                android:maxHeight="200dp"
                android:visibility="visible" />

        </LinearLayout>

    </FrameLayout>

</com.techLabs.nbpdcl.Utils.WhalesDrawerLayout>


