<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.fragment.SourceNetworkFragment"
    android:orientation="vertical"
    android:background="@drawable/bottom_background"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2.0">

        <TextView
            android:id="@+id/fragmentNetwork"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_weight="1.195"
            android:text="@string/networks"
            android:textColor="@color/red"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:id="@+id/format"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="Name"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/networkName"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="@string/network_type"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/networkTypeSpinner"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:textSize="10sp"
            style="@style/tag_spinner_style"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="@string/temperature"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/amb_temp"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#cdcdcd"
        android:layout_marginBottom="2dp"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:backgroundTint="@color/red"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:layout_marginStart="5dp"
            android:text="@string/network_grouping"
            android:textSize="12sp"
            android:textColor="#DE1010"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="PSS Name"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/areaEdt"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

        <!--<Spinner
            android:id="@+id/areaSpinner"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:textSize="10sp"
            style="@style/tag_spinner_style"/>-->

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="@string/voltage_levels"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/voltageLevelEdt"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="GSS Name"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/regionEdt"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="Division"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/group4"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#cdcdcd"
        android:layout_marginTop="5dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>

    <LinearLayout
        android:weightSum="2.0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:orientation="horizontal">

        <TextView
            android:layout_weight="1.35"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="Circle"
            android:textColor="@color/black"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/group5"
            android:layout_weight="0.66"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:background="@drawable/edt_txt_background"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text=""
            android:inputType="textNoSuggestions"
            android:textSize="10sp"/>

    </LinearLayout>

</LinearLayout>