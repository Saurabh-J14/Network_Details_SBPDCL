<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".view.activity.LoginActivity">


    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/login_bg_sand"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/otpCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="200dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="18dp"
        android:clipToPadding="false"
        app:strokeColor="@android:color/white"
        app:strokeWidth="0.6dp"
        android:backgroundTint="#F2C7D3F5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/imglogo"
                android:layout_width="140dp"
                android:layout_height="60dp"
                android:src="@drawable/nbpdcl_sbpdcl_logo"
                android:scaleType="fitCenter"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/userNameEdtTxt"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:hint="@string/username"
                android:background="@drawable/verify_background"
                android:textColor="#FFFFFF"
                android:textColorHint="#CCFFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                app:layout_constraintTop_toBottomOf="@id/imglogo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <EditText
                android:id="@+id/passwordEdtTxt"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:hint="@string/password"
                android:inputType="textPassword"
                android:background="@drawable/verify_background"
                android:textColor="#FFFFFF"
                android:textColorHint="#CCFFFFFF"
                android:paddingStart="16dp"
                android:paddingEnd="42dp"
                app:layout_constraintTop_toBottomOf="@id/userNameEdtTxt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <ImageView
                android:id="@+id/imgVisible"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_visibility_off"
                app:layout_constraintEnd_toEndOf="@id/passwordEdtTxt"
                app:layout_constraintTop_toTopOf="@id/passwordEdtTxt"
                app:layout_constraintBottom_toBottomOf="@id/passwordEdtTxt"/>

            <TextView
                android:id="@+id/loginBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Login"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="@color/white"
                android:paddingHorizontal="30dp"
                android:paddingVertical="12dp"
                android:background="@drawable/btn_login_gradient"
                app:layout_constraintTop_toBottomOf="@id/passwordEdtTxt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tl_labs_net"
            android:textColor="@color/red"
            android:textStyle="bold"
            android:textSize="20sp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <View
                android:id="@+id/v1"
                android:layout_width="85dp"
                android:layout_height="1.5dp"
                android:background="@color/red"/>

            <View
                android:id="@+id/v2"
                android:layout_width="50dp"
                android:layout_height="1.5dp"
                android:background="@color/white"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/a_network_analysis_android_app_using_cyme"
            android:textColor="#EFFFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>