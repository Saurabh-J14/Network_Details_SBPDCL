                        android:layout_height="wrap_content"
                        android:layout_weight="1.45"
                        android:padding="5sp"
                        android:text="@string/number"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <EditText
