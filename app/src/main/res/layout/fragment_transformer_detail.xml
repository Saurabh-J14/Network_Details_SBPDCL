                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="0.58"
                        android:background="@drawable/edt_txt_background"
                        android:padding="4sp"
                        android:text=""
                        android:textColor="@color/black"
                        android:textSize="12sp"
