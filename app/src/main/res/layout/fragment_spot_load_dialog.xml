                    <TextView
                        android:id="@+id/singlePhaseConnectedCapacityExtensionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:paddingStart="5sp"
                        android:text="@string/kva"
                        android:textColor="@color/black"
                        android:textSize="7sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="3dp"
                    android:background="#cdcdcd" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/singlePhaseCustomberTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:padding="5dp"
                        android:text="Customers"
                        android:textColor="@color/black"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/customerAEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/customerBEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/customerCEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
