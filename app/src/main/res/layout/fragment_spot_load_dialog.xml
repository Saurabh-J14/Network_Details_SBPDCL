                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:padding="5dp"
                        android:text="@string/real_power"
                        android:textColor="@color/black"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseRealPowerAEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseRealPowerBEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseRealPowerCEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhaseRealPowerTotalEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhaseRealPowerExtensionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:paddingStart="5sp"
                        android:text="@string/kva"
                        android:textColor="@color/black"
                        android:textSize="7sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="3dp"
                    android:background="#cdcdcd" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/singlePhasePowerFactorTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:padding="5dp"
                        android:text="@string/power_factor"
                        android:textColor="@color/black"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhasePowerFactorAEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhasePowerFactorBEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhasePowerFactorCEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhasePowerFactorTotalEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhasePowerFactorExtensionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:paddingStart="5sp"
                        android:text="@string/kva"
                        android:textColor="@color/black"
                        android:textSize="7sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="3dp"
                    android:background="#cdcdcd" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/singlePhaseConsumptionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:padding="5dp"
                        android:text="@string/consumption"
                        android:textColor="@color/black"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseConsumptionAEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseConsumptionBEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/singlePhaseConsumptionCEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhaseConsumptionTotalEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/singlePhaseConsumptionExtensionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.5"
                        android:paddingStart="5sp"
                        android:text="@string/kva"
                        android:textColor="@color/black"
                        android:textSize="7sp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="3dp"
                    android:background="#cdcdcd" />

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/singlePhaseConnectedCapacityTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.5"
                        android:padding="5dp"
                        android:text="@string/connected_capacity"
                        android:textColor="@color/black"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/ccAEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/ccBEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/edt_txt_background"
                        android:enabled="false"
                        android:gravity="center"
                        android:padding="5dp"
                        android:text="0.0"
                        android:textColor="#cdcdcd"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/ccCEdt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
