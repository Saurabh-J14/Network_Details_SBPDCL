                android:layout_height="fill_parent">

                <TextView
                    android:id="@+id/feederTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="FeederId"
                    android:textAppearance="@style/TextAppearance.AppCompat"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sectionIdTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:maxLines="12"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="SectionId"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/eqIdTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="EqId"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/eqCodeTV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="EqCode"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/loadingATv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="10sp"
                    android:text="LOADINGA"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/loadingBTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="LOADINGB"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/loadingCTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="LOADINGC"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/vaTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="VA"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/vbTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="VB"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/vcTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:paddingLeft="10sp"
                    android:paddingRight="100sp"
                    android:text="VC"
                    android:textColor="@color/blue"
                    android:textSize="12sp" />


            </TableRow>

        </TableLayout>

