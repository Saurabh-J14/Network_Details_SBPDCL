<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background Color -->
    <solid android:color="#F2C7D3F5" />

    <!-- Rounded Corners -->
    <corners android:radius="13dp" />

    <!-- Optional Border -->
    <stroke
        android:width="0.6dp"
        android:color="#FFFFFF" />

    <!-- Padding (optional) -->
    <padding
        android:left="8dp"
        android:top="4dp"
        android:right="8dp"
        android:bottom="4dp" />

</shape>
